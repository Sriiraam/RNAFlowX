process {

    executor = 'local'


    withName: FASTQC_RAW {
        cpus = 2
        memory = '4 GB'
    }


    withName: FASTP_TRIM {
        cpus = 8
        memory = '8 GB'
    }


    withName: FASTQC_TRIMMED {
        cpus = 2
        memory = '4 GB'
    }


    withName: STAR_ALIGN {
        cpus = 8
        memory = '28 GB'
        maxForks = 2
    }


    withName: SAMTOOLS_INDEX {
        cpus = 2
        memory = '4 GB'
    }


    withName: FEATURECOUNTS {
        cpus = 4
        memory = '8 GB'
    }

}
