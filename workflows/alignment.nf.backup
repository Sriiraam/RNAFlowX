include { STAR_ALIGN } from '../modules/star_align'
include { SAMTOOLS_INDEX } from '../modules/samtools_index'


workflow ALIGNMENT {

    take:
    reads
    star_index

    main:

    aligned_bam = STAR_ALIGN(reads, star_index)

    indexed_bam = SAMTOOLS_INDEX(aligned_bam)


    emit:
    bam = indexed_bam.map { sample_id, bam, bai ->
        tuple(sample_id, bam)
    }

}
