nextflow.enable.dsl = 2


params {

    sample_manifest = "data/metadata/sample_manifest.csv"

    reads = "data/raw/*_{1,2}.fastq.gz"

    star_index = "data/reference/star_index"

    gtf = "data/reference/raw/gencode.v49.annotation.gtf"

    outdir = "results"

    threads = 8
}


process {

    executor = 'local'


    withName: FASTQC_RAW {
        cpus = 2
        memory = '4 GB'
    }


    withName: FASTP_TRIM {
        cpus = 8
        memory = '8 GB'
    }


    withName: FASTQC_TRIMMED {
        cpus = 2
        memory = '4 GB'
    }


   withName: STAR_ALIGN {
    cpus = 8
    memory = '28 GB'
    maxForks = 2
}
    withName: SAMTOOLS_INDEX {
        cpus = 2
        memory = '4 GB'
    }


    withName: FEATURECOUNTS {
        cpus = 4
        memory = '8 GB'
    }

}
